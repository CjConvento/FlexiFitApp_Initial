<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ========================= -->
        <!-- MACROS CARD -->
        <!-- ========================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMacrosMain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:strokeWidth="0dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header -->
                <!-- Header (Left: back, Center: chip label, Right: calendar) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Back -->
                    <ImageButton
                        android:id="@+id/btnNutri"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Back"
                        android:src="@drawable/baseline_arrow_left_ios_new_24"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <!-- Center Chip -->
                    <TextView
                        android:id="@+id/tvMacrosTag"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Month 1 - Week 1 - Day 1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:background="@drawable/bg_chip_soft"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:layout_constraintStart_toEndOf="@id/btnNutri"
                        app:layout_constraintEnd_toStartOf="@id/btnOpenCalendar"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"/>

                    <!-- Calendar -->
                    <ImageButton
                        android:id="@+id/btnOpenCalendar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Open Calendar"
                        android:src="@drawable/iconly_calendar"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Chart + Totals Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Donut / Pie Chart container -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="180dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="6dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="0dp">

                        <!-- Replace this FrameLayout with PieChart later -->
                        <FrameLayout
                            android:id="@+id/chartContainer"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="[ Donut Chart ]"
                                android:textStyle="bold"
                                android:alpha="0.6" />

                            <!-- Optional center label -->
                            <TextView
                                android:id="@+id/tvChartCenter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="2200\nkcal"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:alpha="0.0" />
                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Total macros summary -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTotalsTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Macros"
                            android:textStyle="bold"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTotalProtein"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Protein: 0g" />

                        <TextView
                            android:id="@+id/tvTotalCarbs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Carbs: 0g" />

                        <TextView
                            android:id="@+id/tvTotalFats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Fats: 0g" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Intake vs Target (progress rows) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <!-- Protein row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Protein"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvProteinValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0g / 120g"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbProtein"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0" />
                    </LinearLayout>

                    <!-- Carbs row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Carbs"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCarbsValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0g / 220g"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbCarbs"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0" />
                    </LinearLayout>

                    <!-- Fats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Fats"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvFatsValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0g / 80g"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pbFats"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Calories row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Calories"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvCaloriesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 2200 kcal"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/pbCalories"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="0"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================= -->
        <!-- MEAL PLAN CARD -->
        <!-- ========================= -->
        <!-- ========================= -->
        <!-- MEAL PLAN CARD -->
        <!-- ========================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMealPlan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/cardMacrosMain"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvMealPlanTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Meal Plan"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center" />

                <!-- Plan Name Chip -->
                <TextView
                    android:id="@+id/tvMealPlanChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_chip_soft"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:includeFontPadding="false"
                    android:text="Lose Weight Vegan Meal Plan"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Inner container -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMealInner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F6F7FB">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvMealSections"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:padding="14dp"
                        xmlns:tools="http://schemas.android.com/tools"
                        tools:listitem="@layout/item_meal_section"
                        tools:itemCount="4" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSkipMealPlan"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Skip"
                        app:backgroundTint="@null"
                        android:background="@drawable/btn_gradient"
                        app:cornerRadius="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDoneMealPlan"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Done"
                        app:backgroundTint="@null"
                        android:background="@drawable/btn_gradient"
                        app:cornerRadius="16dp" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================= -->
        <!-- WATER INTAKE CARD -->
        <!-- ========================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWater"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="40dp"
            app:layout_constraintTop_toBottomOf="@id/cardMealPlan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Water Intake"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvWaterValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ml / 2500 ml"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbWater"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0" />

                <!-- optional quick actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddWater"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:backgroundTint="@null"
                        android:background="@drawable/btn_gradient"
                        android:text="Add +250ml"
                        app:cornerRadius="14dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetWater"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:backgroundTint="@null"
                        android:background="@drawable/btn_gradient"
                        android:layout_marginStart="10dp"
                        android:text="Reset"
                        app:cornerRadius="14dp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>