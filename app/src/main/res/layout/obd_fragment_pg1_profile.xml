<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_white"
    android:padding="18dp">

    <include
        android:id="@+id/header"
        layout="@layout/view_onboarding_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardContainer"
        android:layout_width="371dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        app:contentPadding="18dp"
        app:cardCornerRadius="25dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnConfirm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:strokeWidth="0dp">

        <!-- ONE MAIN WRAPPER (required because MaterialCardView is FrameLayout-like) -->
        <LinearLayout
            android:id="@+id/pg1p5cardMainWrap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- TITLE + SUBTITLE WRAPPER (outside content container but inside card) -->
            <LinearLayout
                android:id="@+id/ProfiletitleWrap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/pg2tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Let's Get to Know About You"
                    android:textColor="@color/colorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pg1tvSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Basic profile information"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- CONTENT AREA (fills the remaining space) -->
            <FrameLayout
                android:id="@+id/contentArea"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:layout_constraintTop_toBottomOf="@id/pg1tvSubtitle"
                android:foregroundGravity="center">

                <!-- OPTIONAL: center the content vertically inside remaining space -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/pg1card"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="18dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/header">


                    <!-- AGE -->
                    <TextView
                        android:id="@+id/tvAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Age"
                        android:textColor="@color/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- AGE WHEEL (wrap-around) -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/ageWheelWrap"
                        android:layout_width="140dp"
                        android:layout_height="220dp"
                        android:layout_marginTop="10dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAge"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <!-- UP ARROW -->
                        <ImageButton
                            android:id="@+id/btnAgeUp"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@android:color/transparent"
                            android:src="@drawable/baseline_keyboard_arrow_up_24"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <!-- RECYCLER (center area) -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvAge"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:clipToPadding="false"
                            android:overScrollMode="never"
                            android:paddingTop="30dp"
                            android:paddingBottom="60dp"
                            app:layout_constraintTop_toBottomOf="@id/btnAgeUp"
                            app:layout_constraintBottom_toTopOf="@id/btnAgeDown"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <!-- CENTER SELECTED BOX -->
                        <TextView
                            android:id="@+id/tvAgeSelected"
                            android:layout_width="72dp"
                            android:layout_height="42dp"
                            android:background="@drawable/flexifit_border"
                            android:gravity="center"
                            android:text=""
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorPrimary"
                            app:layout_constraintTop_toTopOf="@id/rvAge"
                            app:layout_constraintBottom_toBottomOf="@id/rvAge"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <!-- DOWN ARROW -->
                        <ImageButton
                            android:id="@+id/btnAgeDown"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@android:color/transparent"
                            android:src="@drawable/baseline_keyboard_arrow_down_24"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- GENDER -->
                        <TextView
                            android:id="@+id/tvGender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gender"
                            android:textColor="@color/colorPrimary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/ageWheelWrap" />

                        <!-- Placeholder container for gender buttons/icons -->
                        <LinearLayout
                            android:id="@+id/genderRow"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvGender">

                            <!-- Male card -->
                            <LinearLayout
                                android:id="@+id/cardMale"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_marginEnd="10dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_gender_card"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <ImageView
                                    android:id="@+id/ivMale"
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/ic_gender_male"
                                    android:contentDescription="Male icon" />

                                <TextView
                                    android:id="@+id/tvMale"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="Male"
                                    android:textColor="@color/colorPrimary"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Female card -->
                            <LinearLayout
                                android:id="@+id/cardFemale"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_width="0dp"
                                android:layout_height="120dp"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_gender_card"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <ImageView
                                    android:id="@+id/ivFemale"
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:contentDescription="Female icon"
                                    android:background="@drawable/ic_gender_female"/>

                                <TextView
                                    android:id="@+id/tvFemale"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="Female"
                                    android:textColor="@color/colorPrimary"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                        </LinearLayout>

                    <!-- NAV arrows -->

                </androidx.constraintlayout.widget.ConstraintLayout>

            </FrameLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/btnConfirm"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:background="@drawable/btn_gradient"
        android:paddingLeft="40dp"
        android:paddingRight="40dp"
        android:text="Confirm"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>