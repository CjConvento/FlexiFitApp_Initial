<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ========= TOP GREETING ========= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tv_my_workout_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:textColor="@color/textSecondary" />

            <TextView
                android:id="@+id/tv_user_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hi, User"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/tv_my_workout_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your overview, workout plan, and daily stats."
                android:textSize="14sp"
                android:textColor="@color/textSecondary"
                android:paddingTop="2dp"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <!-- ========= USER DETAILS (WEIGHT / HEIGHT / GOAL) ========= -->
        <LinearLayout
            android:id="@+id/layout_user_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingBottom="12dp">

            <!-- Current Weight -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/tv_user_weight_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weight"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:textColor="@color/textSecondary" />

                <TextView
                    android:id="@+id/tv_user_weight_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="72.5 kg"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />
            </LinearLayout>

            <!-- Height -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <TextView
                    android:id="@+id/tv_user_height_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Height"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:textColor="@color/textSecondary" />

                <TextView
                    android:id="@+id/tv_user_height_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="170 cm"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />
            </LinearLayout>

            <!-- Goal -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/tv_user_goal_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Goal"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:textColor="@color/textSecondary" />

                <TextView
                    android:id="@+id/tv_user_goal_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fat Loss"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />
            </LinearLayout>

        </LinearLayout>

        <!-- ========= QUICK STATS (Flutter-style row cards) ========= -->
        <LinearLayout
            android:id="@+id/layout_quick_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingBottom="12dp">

            <!-- Calories In -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tv_quick_cal_in_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cal In"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tv_quick_cal_in_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,350"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary" />

                    <TextView
                        android:id="@+id/tv_quick_cal_in_target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="of 2,000 kcal"
                        android:textSize="11sp"
                        android:textColor="@color/textSecondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Calories Out -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tv_quick_cal_out_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cal Out"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tv_quick_cal_out_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="430"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary" />

                    <TextView
                        android:id="@+id/tv_quick_cal_out_target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="today burned"
                        android:textSize="11sp"
                        android:textColor="@color/textSecondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Steps -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="18dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tv_quick_steps_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Steps"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/tv_quick_steps_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5,200"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary" />

                    <TextView
                        android:id="@+id/tv_quick_steps_target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="goal: 8,000"
                        android:textSize="11sp"
                        android:textColor="@color/textSecondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ========= CURRENT PROGRAM CARD (Flutter card style) ========= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_current_program"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_current_program_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Program"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:textColor="@color/textSecondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp">

                    <TextView
                        android:id="@+id/tv_current_program_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Beginner Full Body (3x/week)"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_current_level"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beginner"
                        android:textSize="12sp"
                        android:textColor="@android:color/white"
                        app:chipBackgroundColor="@color/colorPrimary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_current_program_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Focus on basic compound movements to build strength and proper form."
                    android:textSize="14sp"
                    android:textColor="@color/textSecondary"
                    android:paddingTop="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ========= CALORIES BURNED GRAPH (card) ========= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calories Burned (Last 7 Days)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_calories_graph"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <FrameLayout
                android:id="@+id/chart_calories_burned"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#EEF1F7">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Graph Placeholder"
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:layout_gravity="center" />
            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ========= MACROS & CALORIES CARD (3-column Flutter style) ========= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Macros &amp; Calories Today"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_macros_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Calories Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/tv_calories_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calories"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary" />

                    <TextView
                        android:id="@+id/tv_calories_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 1,350 / 2,000 kcal"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_calories"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginBottom="12dp"
                    android:progress="68"
                    android:max="100"
                    android:progressDrawable="@drawable/progress_rounded_calories" />

                <!-- 3-column macros row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Protein -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Protein"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary" />

                        <TextView
                            android:id="@+id/tv_protein_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="65g / 100g"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary" />

                        <ProgressBar
                            android:id="@+id/progress_protein"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="4dp"
                            android:progress="65"
                            android:max="100"
                            android:progressDrawable="@drawable/progress_rounded_calories" />
                    </LinearLayout>

                    <!-- Carbs -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingHorizontal="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Carbs"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary" />

                        <TextView
                            android:id="@+id/tv_carbs_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="120g / 300g"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary" />

                        <ProgressBar
                            android:id="@+id/progress_carbs"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="4dp"
                            android:progress="40"
                            android:max="100"
                            android:progressDrawable="@drawable/progress_rounded_calories" />
                    </LinearLayout>

                    <!-- Fats -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fats"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/textPrimary" />

                        <TextView
                            android:id="@+id/tv_fats_details"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="33g / 60g"
                            android:textSize="12sp"
                            android:textColor="@color/textSecondary" />

                        <ProgressBar
                            android:id="@+id/progress_fats"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="4dp"
                            android:progress="55"
                            android:max="100"
                            android:progressDrawable="@drawable/progress_rounded_calories" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ========= TODAY'S WORKOUT ========= -->
        <TextView
            android:id="@+id/tv_today_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today’s Workout"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_today_workout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day 1 – Full Body A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Squats – 3 sets x 10–12 reps"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Bench Press – 3 sets x 8–10 reps"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Lat Pulldown – 3 sets x 10–12 reps"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Shoulder Press – 3 sets x 10 reps"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Plank – 3 sets x 30–45 seconds"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ========= RECOMMENDED PROGRAMS ========= -->
        <TextView
            android:id="@+id/tv_recommended_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recommended Programs for You"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_program_beginner_full_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="18dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Beginner Full Body"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3 days per week • Ideal for true beginners"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary"
                    android:paddingTop="4dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_program_upper_lower"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="18dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upper / Lower Split"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="4 days per week • For progressing beginners"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary"
                    android:paddingTop="4dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_program_5day_split"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5-Day Push/Pull/Legs"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="For intermediate users with solid foundation"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary"
                    android:paddingTop="4dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
