    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp" app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@android:color/transparent"> <FrameLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
