<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".googleauth.CreateUsernameActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
        app:title="Complete Google Sign Up"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_chevron_r_circle" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="30dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Complete Your Account"
                            android:textAlignment="center"
                            android:textColor="@color/colorPrimary"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Your Google account is connected. Choose a username to continue."
                            android:textAlignment="center"
                            android:textColor="@color/textSecondary"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="28dp"
                            android:text="Name"
                            android:textColor="@color/textSecondary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvGoogleNameValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/flexifit_border"
                            android:padding="14dp"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Email"
                            android:textColor="@color/textSecondary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvGoogleEmailValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/flexifit_border"
                            android:padding="14dp"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="20dp"
                            android:background="@drawable/flexifit_border"
                            android:paddingHorizontal="8dp"
                            app:hintTextColor="@color/textPrimary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCreateUsername"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:drawableStart="@drawable/baseline_person_pin_24"
                                android:drawableTint="@color/colorPrimary"
                                android:hint="Username"
                                android:padding="8dp"
                                android:textColor="@color/textPrimary"
                                android:textColorHint="@color/textPrimary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnContinueCreateUsername"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="30dp"
                            android:background="@drawable/btn_gradient"
                            android:text="Continue"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="@null"
                            app:cornerRadius="24dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <FrameLayout
            android:id="@+id/loadingOverlayCreateUsername"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                app:indicatorSize="60dp"
                app:trackThickness="5dp" />
        </FrameLayout>

    </FrameLayout>

</LinearLayout>