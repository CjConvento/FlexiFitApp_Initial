<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dashboard_wrapper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="50dp">

        <!--        HEADER-->
        <include
            android:id="@+id/dashboardHeader"
            layout="@layout/drawer_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            app:layout_constraintTop_toTopOf="parent" />

<!--        FITNESS LEVEL-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/dashboardHeader">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgLevelIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_level_award" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Fitness Level"
                        android:textSize="12sp"
                        android:textColor="@color/textSecondary" />

                    <TextView
                        android:id="@+id/txtLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beginner"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary" />
                </LinearLayout>



            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

<!--        BMI-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBMI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:layout_marginTop="-5dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/cardLevel">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bmi_card_full"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvBMITitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BMI (Body Mass Index)"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvBMIStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="You have a normal weight"
                    android:textColor="@color/white"
                    android:alpha="0.9"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvBMITitle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBMIViewMore"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginTop="16dp"
                    android:text="View More"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/bg_btn_bmi"
                    app:cornerRadius="20dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvBMIStatus" />

                <FrameLayout
                    android:id="@+id/layoutBMIChart"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <View
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_white_circle_bmi" />

                    <TextView
                        android:id="@+id/txtBMIScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="20.1"
                        android:textColor="#C58BF2"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

<!--        CALORIE STATUS-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCalories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            android:layout_marginTop="1dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/cardBMI">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Calorie Status"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/textPrimary"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Intake"
                            android:textColor="@color/textSecondary"/>
                        <TextView
                            android:id="@+id/txtCalorieIntake"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0 / 2000 kcal"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressIntake"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:trackThickness="8dp"
                        app:trackCornerRadius="4dp"
                        app:indicatorColor="#7B61FF"
                        app:trackColor="#E0E0E0"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Burned"
                            android:textColor="@color/textSecondary"/>
                        <TextView
                            android:id="@+id/txtCaloriesBurned"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0 kcal"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBurned"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:trackThickness="8dp"
                        app:trackCornerRadius="4dp"
                        app:indicatorColor="#FF6B6B"
                        app:trackColor="#E0E0E0"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

<!--        CALORIE TRACK-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCalorieTrack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/cardCalories"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textColor="@color/textPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvNetCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="2300 kcal"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Total Net Calories"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvNetCalories" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressRing"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:indicatorDirectionCircular="clockwise"
                    app:indicatorSize="100dp"
                    app:indicatorColor="@color/colorPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:trackColor="@color/colorPrimary"
                    app:trackCornerRadius="999dp"
                    app:trackThickness="12dp" />

                <TextView
                    android:id="@+id/tvLeftCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="2300 kcal\nleft"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="@id/progressRing"
                    app:layout_constraintEnd_toEndOf="@id/progressRing"
                    app:layout_constraintTop_toTopOf="@id/progressRing"
                    app:layout_constraintBottom_toBottomOf="@id/progressRing" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

<!--        WORKOUT CURRENT SESSION-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardToday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="22dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:layout_constraintTop_toBottomOf="@id/cardCalorieTrack">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp">
                    <TextView
                        android:id="@+id/txtDayWeek"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upcoming Workout"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/btnSeeMoreWorkouts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="See more"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp" />
                </RelativeLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemWorkout1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgWorkout1"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_cardio"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp"
                            app:layout_constraintStart_toEndOf="@id/imgWorkout1"
                            app:layout_constraintEnd_toStartOf="@id/btnGoWorkout1"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">
                            <TextView
                                android:id="@+id/txtWorkoutName1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PushUp"
                                android:textStyle="bold"
                                android:textColor="@color/textPrimary" />
                            <TextView
                                android:id="@+id/txtWorkoutTime1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Workout 1"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />
                        </LinearLayout>
                        <ImageButton
                            android:id="@+id/btnGoWorkout1"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@android:color/transparent"
                            android:src="@drawable/baseline_arrow_right_ios_new_24"
                            android:padding="8dp"
                            app:tint="@color/colorPrimary"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/itemWorkout2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="8dp"
                    app:strokeWidth="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/imgWorkout2"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_cardio"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp"
                            app:layout_constraintStart_toEndOf="@id/imgWorkout2"
                            app:layout_constraintEnd_toStartOf="@id/btnGoWorkout2"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">
                            <TextView
                                android:id="@+id/txtWorkoutName2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Squats"
                                android:textStyle="bold"
                                android:textColor="@color/textPrimary" />
                            <TextView
                                android:id="@+id/txtWorkoutTime2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Workout 2"
                                android:textSize="12sp"
                                android:textColor="@color/textSecondary" />
                        </LinearLayout>
                        <ImageButton
                            android:id="@+id/btnGoWorkout2"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@android:color/transparent"
                            android:src="@drawable/baseline_arrow_right_ios_new_24"
                            android:padding="8dp"
                            app:tint="@color/colorPrimary"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

<!--        TODAY MEALS-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMeal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/cardToday">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/txtTodayMealsHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="Today Meals"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerMealType"
                        android:layout_width="wrap_content"
                        android:layout_height="35dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_spinner_soft"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        tools:listitem="@android:layout/simple_spinner_item"
                        android:entries="@array/meal_categories" />

                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/mealItemsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/item_meal_food"></include>
                    <include layout="@layout/item_meal_food"></include>


                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!--        WATER INTAKE-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWater"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/cardMeal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="33dp">

                <LinearLayout
                    android:id="@+id/textGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="50dp"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/waterGlass">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Water Intake"
                        android:textColor="@color/textPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtWaterCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0/8"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.7"
                        android:text="glasses today"
                        android:textColor="@color/textPrimary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddWater"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/btn_gradient"
                        android:minHeight="0dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="Add +"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:backgroundTint="@null"
                        app:cornerRadius="20dp" />
                </LinearLayout>

                <com.example.flexifitapp.custom.WaterGlassView
                    android:id="@+id/waterGlass"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>