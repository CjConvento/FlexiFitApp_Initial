<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:strokeWidth="0dp"
            android:padding="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/textSecondary"
                    android:text="Your personal details and fitness information"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:textColor="@color/textPrimary"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="10dp"
                        app:cardUseCompatPadding="true"
                        app:strokeWidth="0dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/txtProfileHandle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="user name"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Sections -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="0dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/imgAvatar"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            app:cornerRadius="14dp"
                            app:card_elevation="9dp"
                        />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="User Name"
                                android:textColor="@color/textPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvGoalSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="User Name"
                                android:textColor="@color/textSecondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEdit"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Edit"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="@null"
                            android:background="@drawable/btn_gradient"
                            app:cornerRadius="14dp" />

                    </LinearLayout>

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <!-- Height -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/btn_gradient"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvHeightValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10 cm"
                                android:textColor="@color/textPrimary"
                                android:textStyle="bold"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Height"
                                android:textColor="#B0B0B0"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <!-- Weight -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/btn_gradient"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvWeightValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kg"
                                android:textColor="@color/textPrimary"
                                android:textStyle="bold"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Weight"
                                android:textColor="#B0B0B0"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <!-- Age -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/btn_gradient"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAgeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 yo"
                                android:textColor="@color/textPrimary"
                                android:textStyle="bold"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Age"
                                android:textColor="#B0B0B0"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Basic Information -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="0dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="@android:color/black">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Basic Information"
                                android:textColor="@color/textPrimary"
                                android:textStyle="bold"/>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/bg_edit"
                                android:tint="@color/colorPrimary"
                                android:contentDescription="Edit"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Email: baybum@example.com&#10;Gender: Male&#10;Age: 22"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Body Metrics -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="9dp"
                    app:strokeWidth="0dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Body Metrics"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/textPrimary"
                            android:text="Height: 170 cm&#10;Current Weight: 68 kg&#10;BMI: 23.5&#10;BMI Category: Normal"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Personal Goals -->
                <com.google.android.material.card.MaterialCardView
                    xmlns:android="http://schemas.android.com/apk/res/android"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/black">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Personal Goals"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/textPrimary"
                            android:text="Fitness Goal: Muscle Gain, Lose Fat&#10;Body Composition Goal: Lose Weight"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Fitness Level -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="true"
                    app:strokeWidth="0dp"
                    app:strokeColor="@android:color/black">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fitness Level"
                            android:textColor="@color/textPrimary"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/textPrimary"
                            android:text="Current Level: Intermediate"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="26dp"
            android:paddingEnd="26dp"
            android:paddingBottom="26dp">


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update Profile"
                app:backgroundTint="@null"
                android:background="@drawable/btn_gradient"
                app:cornerRadius="18dp"
                app:strokeWidth="0dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>