<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TITLE -->
        <TextView
            android:id="@+id/tv_my_workout_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Workout"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tv_my_workout_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Here’s your current workout plan and today’s session."
            android:textSize="14sp"
            android:textColor="@color/textPrimary"
            android:paddingBottom="16dp" />

        <!-- CURRENT PROGRAM CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_current_program"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_current_program_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Program"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:id="@+id/tv_current_program_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Beginner Full Body (3x/week)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tv_current_program_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Focus on basic compound movements to build strength and proper form."
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/tv_current_program_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Beginner"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    app:cornerRadius="50dp"
                    app:backgroundTint="#1D3C78"
                    app:iconGravity="textStart"
                    android:elevation="0dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- TODAY'S WORKOUT -->
        <TextView
            android:id="@+id/tv_today_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today’s Workout"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_today_workout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day 1 – Full Body A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="8dp" />

                <!-- WARM-UP SECTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Warm-up"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• 5–10 minutes light cardio (brisk walk, cycling, or treadmill)"
                    android:textSize="14sp"
                    android:paddingBottom="12dp" />

                <!-- MAIN WORKOUT WITH REST TIME PER SET -->

                <!-- WARM-UP SECTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Main Workout"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Squats – 3 sets x 10–12 reps • Rest 60–90s between sets"
                    android:textSize="14sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Bench Press – 3 sets x 8–10 reps • Rest 60–90s between sets"
                    android:textSize="14sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Lat Pulldown – 3 sets x 10–12 reps • Rest 60–90s between sets"
                    android:textSize="14sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Shoulder Press – 3 sets x 10 reps • Rest 60–90s between sets"
                    android:textSize="14sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Plank – 3 sets x 30–45 seconds • Rest 45–60s between sets"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- RECOMMENDED PROGRAMS -->
        <TextView
            android:id="@+id/tv_recommended_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recommended Programs for You"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_program_beginner_full_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Beginner Full Body"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3 days per week • Ideal for true beginners"
                    android:textSize="13sp"
                    android:paddingTop="4dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_program_upper_lower"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upper / Lower Split"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="4 days per week • For progressing beginners"
                    android:textSize="13sp"
                    android:textColor="@color/textPrimary"
                    android:paddingTop="4dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


    </LinearLayout>

</androidx.core.widget.NestedScrollView>
