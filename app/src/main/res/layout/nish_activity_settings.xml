<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#262626"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:backgroundTint="@android:color/transparent"
                android:text="Back"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:strokeColor="#3A3A3A"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Customize FlexiFit behavior, appearance and account security."
            android:textColor="#B0B0B0"
            android:textSize="12sp" />

        <!-- ===================== -->
        <!-- Behavior -->
        <!-- ===================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Behavior"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_option_card"
            android:orientation="vertical"
            android:padding="14dp">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swWorkoutReminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Workout Reminder"
                android:textColor="#FFFFFF"
                app:thumbTint="#B9F6EA"
                app:trackTint="#4A4A4A" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swProgressUpdates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Progress Updates"
                android:textColor="#FFFFFF"
                app:thumbTint="#B9F6EA"
                app:trackTint="#4A4A4A" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swAchievementAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Achievement Alerts"
                android:textColor="#FFFFFF"
                app:thumbTint="#B9F6EA"
                app:trackTint="#4A4A4A" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swEmailNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email Notifications"
                android:textColor="#FFFFFF"
                app:thumbTint="#B9F6EA"
                app:trackTint="#4A4A4A" />
        </LinearLayout>

        <!-- ===================== -->
        <!-- Appearance -->
        <!-- ===================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Appearance"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnThemeColor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@android:color/transparent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Theme Color"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="18dp"
            app:strokeColor="#3A3A3A"
            app:strokeWidth="1dp" />

        <!-- ===================== -->
        <!-- Privacy & Security -->
        <!-- ===================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Privacy and Security"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_option_card"
            android:orientation="vertical"
            android:padding="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="@android:color/transparent"
                android:text="Change Password"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp"
                app:strokeColor="#3A3A3A"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@android:color/transparent"
                android:text="Update Email"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp"
                app:strokeColor="#3A3A3A"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="22dp" />

        <!-- Logout (bottom CTA like your "Next") -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Log Out"
            android:textAllCaps="false"
            android:textColor="#0A0A0A"
            app:backgroundTint="#B9F6EA"
            app:cornerRadius="18dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="18dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
