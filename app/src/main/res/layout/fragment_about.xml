<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050711"
    android:padding="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP TITLE (Flutter-style big title) -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FlexiFit"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:textColor="@android:color/white"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvAppSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI-Powered Fitness Companion"
            android:textSize="14sp"
            android:textColor="#9CA3AF"
            android:paddingBottom="16dp" />

        <!-- TAGS / CHIPS ROW -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Workout"
                android:textSize="12sp"
                android:textColor="#E5E7EB"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:background="@drawable/chip_bg"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nutrition"
                android:textSize="12sp"
                android:textColor="#E5E7EB"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:background="@drawable/chip_bg"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI"
                android:textSize="12sp"
                android:textColor="#E5E7EB"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:background="@drawable/chip_bg"
                android:gravity="center"
                android:includeFontPadding="false" />
        </LinearLayout>


        <!-- MAIN CARD (Flutter-like Card) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="#111827">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvAboutTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About FlexiFit"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/tvAboutDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FlexiFit is an AI-powered fitness companion designed to help users achieve their health and workout goals through personalized workout programs, macro-nutrition tracking, and intelligent recommendations. It adapts to the user’s progress, suggests meals, and helps maintain consistency over time."
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#D1D5DB"
                    android:paddingBottom="16dp" />

                <TextView
                    android:id="@+id/tvFeatureHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Core Features"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/tvFeatures"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Personalized workout generation\n• Daily macro &amp; calorie tracking\n• Smart meal planning system\n• Progress visualization &amp; analytics\n• User profile customization"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#D1D5DB"
                    android:paddingBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F2933"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvDeveloper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Developed by\nFlexiFit Development Team"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"
                    android:textColor="#9CA3AF" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
