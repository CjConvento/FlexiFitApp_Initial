<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    tools:context=".SignupActivity">

    <!-- APP BAR (same as Login) -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
        app:title="FlexiFit"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- SIGN UP CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSignup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="30dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="20dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/surface"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- TITLE -->
                    <TextView
                        android:id="@+id/signupTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sign Up"
                        android:textAlignment="center"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/aut_color" />

                    <!-- NAME -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="32dp"
                        android:background="@drawable/flexifit_border"
                        app:hintTextColor="@color/textPrimary"
                        android:paddingHorizontal="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/signup_name"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Name"
                            android:background="@android:color/transparent"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/textPrimary"
                            android:drawableStart="@drawable/baseline_person_pin_24"
                            android:drawableTint="@color/colorPrimary"
                            android:padding="8dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ADDRESS -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/flexifit_border"
                        app:hintTextColor="@color/textPrimary"
                        android:paddingHorizontal="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/signup_address"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Address"
                            android:background="@android:color/transparent"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/textPrimary"
                            android:drawableStart="@drawable/baseline_location_on_24"
                            android:drawableTint="@color/colorPrimary"
                            android:padding="8dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- EMAIL -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/flexifit_border"
                        app:hintTextColor="@color/textPrimary"
                        android:paddingHorizontal="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/signup_email"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Email"
                            android:inputType="textEmailAddress"
                            android:background="@android:color/transparent"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/textPrimary"
                            android:drawableStart="@drawable/baseline_email_24"
                            android:drawableTint="@color/colorPrimary"
                            android:padding="8dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- USERNAME -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/flexifit_border"
                        app:hintTextColor="@color/textSecondary"
                        android:paddingHorizontal="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/signup_username"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Username"
                            android:background="@android:color/transparent"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/textPrimary"
                            android:drawableStart="@drawable/baseline_person_pin_24"
                            android:drawableTint="@color/colorPrimary"
                            android:padding="8dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PASSWORD -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilpass"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/flexifit_border"
                        android:paddingHorizontal="8dp"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/colorPrimary"
                        app:hintTextColor="@color/textPrimary"
                        app:errorIconDrawable="@null">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/signup_password"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Password"
                            android:inputType="textPassword"
                            android:background="@android:color/transparent"
                            android:textColor="@color/textPrimary"
                            android:textColorHint="@color/textPrimary"
                            android:drawableStart="@drawable/baseline_lock_24"
                            android:drawableTint="@color/colorPrimary"
                            android:padding="8dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- SIGN UP BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/signup_button"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="30dp"
                        android:text="Sign Up"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/colorPrimary"
                        app:cornerRadius="24dp"/>

                    <!-- REDIRECT -->
                    <TextView
                        android:id="@+id/loginRedirectText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already a user? Login"
                        android:layout_gravity="center"
                        android:padding="8dp"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/redirect_color"
                        android:textSize="14sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
