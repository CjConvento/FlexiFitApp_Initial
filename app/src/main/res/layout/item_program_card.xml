<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_gender_card"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvProgramTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cardio Program"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvProgramDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="This program is recommended for losing fat for intermediate users who trains at home"
        android:textSize="12sp"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvProgramTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Level: Intermediate"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="@color/colorPrimary"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvProgramDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvEnv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Environment: Home"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="@color/colorPrimary"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvLevel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/ivCheck"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@android:drawable/checkbox_on_background"
        android:contentDescription="Selected"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>