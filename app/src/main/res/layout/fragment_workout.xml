<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorBackground"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <ImageButton
                android:id="@+id/btnBackWorkoutPlan"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Back"
                android:padding="10dp"
                android:src="@drawable/baseline_arrow_left_ios_new_24"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDatePill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                app:layout_constraintBottom_toBottomOf="@id/btnBackWorkoutPlan"
                app:layout_constraintEnd_toStartOf="@id/btnOpenCalendar"
                app:layout_constraintStart_toEndOf="@id/btnBackWorkoutPlan"
                app:layout_constraintTop_toTopOf="@id/btnBackWorkoutPlan">

                <TextView
                    android:id="@+id/tvWorkoutPlanDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="8dp"
                    android:backgroundTint="@null"
                    android:text="Month 1 - Week 1 - Day 1"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <ImageButton
                android:id="@+id/btnOpenCalendar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="Calendar"
                android:padding="10dp"
                android:src="@drawable/iconly_calendar"
                app:layout_constraintBottom_toBottomOf="@id/btnBackWorkoutPlan"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnBackWorkoutPlan" />

            <ImageButton
                android:id="@+id/btnPrevProgram"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="50dp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@drawable/baseline_arrow_left_ios_new_24"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnBackWorkoutPlan" />

            <TextView
                android:id="@+id/tvProgramHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Program 1"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/btnPrevProgram"
                app:layout_constraintEnd_toStartOf="@id/btnNextProgram"
                app:layout_constraintStart_toEndOf="@id/btnPrevProgram"
                app:layout_constraintTop_toTopOf="@id/btnPrevProgram" />

            <ImageButton
                android:id="@+id/btnNextProgram"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="50dp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@drawable/baseline_arrow_right_ios_new_24"
                app:layout_constraintBottom_toBottomOf="@id/btnPrevProgram"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnPrevProgram" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProgramInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/tvProgramHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="25dp">

                    <TextView
                        android:id="@+id/tvCurrentProgramName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Strength Beginner Home Program"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProgramProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lorem ipsum labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip erit in vo">
                    </TextView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvSessionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="Workout Session"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardProgramInfo" />

            <LinearLayout
                android:id="@+id/layoutStatusCycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="@id/tvSessionLabel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvSessionLabel">

                <TextView
                    android:id="@+id/tvWorkoutStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="In Progress"
                    android:textSize="11sp"
                    android:textStyle="italic"
                    android:textColor="@color/colorPrimary" />

                <ImageView
                    android:id="@+id/ivStatusCycle"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_status_cycle"
                    app:tint="@color/colorPrimary" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressWorkoutLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSessionLabel" />

            <TextView
                android:id="@+id/tvWorkoutError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Connection error, babe. Check your API!"
                android:textColor="#EF4444"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/progressWorkoutLoading" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetryWorkout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retry"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvWorkoutError" />

            <LinearLayout
                android:id="@+id/layoutWarmupHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvSessionLabel">

                <TextView
                    android:id="@+id/tvWarmupHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Warmup"
                    android:layout_marginStart="4dp"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnToggleWarmup"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24"
                    app:tint="#6F8FCB" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWarmupItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/layoutWarmupHeader"
                tools:listitem="@layout/item_workout_entry"
                tools:itemCount="2"/>

            <LinearLayout
                android:id="@+id/layoutWorkoutHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp"
                app:layout_constraintTop_toBottomOf="@id/rvWarmupItems">

                <TextView
                    android:id="@+id/tvWorkoutsHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Main Workouts"
                    android:layout_marginStart="12dp"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnToggleWorkouts"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24"
                    app:tint="#6F8FCB" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWorkoutItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintTop_toBottomOf="@id/layoutWorkoutHeader"
                tools:listitem="@layout/item_workout_entry"
                tools:itemCount="2"/>

            <LinearLayout
                android:id="@+id/layoutWorkoutSessionBottomActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="15dp"
                app:layout_constraintTop_toBottomOf="@id/rvWorkoutItems"
                app:layout_constraintBottom_toBottomOf="parent">

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>