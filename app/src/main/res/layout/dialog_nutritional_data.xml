<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="10dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:padding="2dp"
                android:src="@drawable/baseline_arrow_left_ios_new_24" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Nutritional Data"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Nutritional Goal -->
            <LinearLayout
                android:id="@+id/rowNutritionalGoalHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nutritional Goal"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/ivNutritionalGoalAction"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle Nutritional Goal"
                    android:padding="2dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutNutritionalGoalContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvNutritionalGoalValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DADADA" />

            <!-- Age -->
            <LinearLayout
                android:id="@+id/rowAgeHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Age"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/ivAgeAction"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle Age"
                    android:padding="2dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAgeContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvAgeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DADADA" />

            <!-- Height -->
            <LinearLayout
                android:id="@+id/rowHeightHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Height"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/ivHeightAction"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle Height"
                    android:padding="2dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutHeightContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvHeightValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DADADA" />

            <!-- Current Weight -->
            <LinearLayout
                android:id="@+id/rowCurrentWeightHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Current Weight"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/ivCurrentWeightAction"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle Current Weight"
                    android:padding="2dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutCurrentWeightContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvCurrentWeightValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DADADA" />

            <!-- Target Weight -->
            <LinearLayout
                android:id="@+id/rowTargetWeightHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Target Weight"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/ivTargetWeightAction"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle Target Weight"
                    android:padding="2dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTargetWeightContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvTargetWeightValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DADADA" />

            <!-- BMI -->
            <LinearLayout
                android:id="@+id/rowBmiHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BMI"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/ivBmiAction"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle BMI"
                    android:padding="2dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutBmiContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvBmiValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DADADA" />

            <!-- BMI Category -->
            <LinearLayout
                android:id="@+id/rowBmiCategoryHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BMI Category"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/ivBmiCategoryAction"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle BMI Category"
                    android:padding="2dp"
                    android:src="@drawable/baseline_keyboard_arrow_down_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutBmiCategoryContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvBmiCategoryValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>