<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_white"
    android:padding="18dp">

    <include
        android:id="@+id/header"
        layout="@layout/view_onboarding_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="531dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        app:contentPadding="18dp"
        app:cardUseCompatPadding="true"
        app:cardCornerRadius="25dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/pg1p5cardMainWrap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/MetricstitleWrap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Metrics"
                    android:textColor="@color/colorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Basic profile information"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/contentArea"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:foregroundGravity="center">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/lcard"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="18dp">

                    <!-- HEIGHT -->
                    <TextView
                        android:id="@+id/tvHeightLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Height (cm)"
                        android:textColor="@color/colorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <LinearLayout
                        android:id="@+id/heightPicker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/tvHeightLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/tvHeightPrev"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="169"
                            android:textColor="@color/colorPrimary"
                            android:textSize="12sp" />

                        <ImageButton
                            android:id="@+id/btnHeightUp"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Height up"
                            android:src="@drawable/baseline_keyboard_arrow_up_24" />

                        <FrameLayout
                            android:layout_width="88dp"
                            android:layout_height="40dp">

                            <TextView
                                android:id="@+id/tvHeightSelected"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="170"
                                android:textColor="@color/colorPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/flexifit_border"
                                android:clickable="false"
                                android:focusable="false"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <ImageButton
                            android:id="@+id/btnHeightDown"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Height down"
                            android:src="@drawable/baseline_keyboard_arrow_down_24" />

                        <TextView
                            android:id="@+id/tvHeightNext"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="171"
                            android:textColor="@color/colorPrimary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- LEFT: CURRENT WEIGHT -->
                    <TextView
                        android:id="@+id/tvWeightLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:text="Weight (kg)"
                        android:textColor="@color/colorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/heightPicker"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/guidelineCenter"
                        app:layout_constraintHorizontal_bias="0.5" />

                    <LinearLayout
                        android:id="@+id/weightPicker"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/tvWeightLabel"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/guidelineCenter">

                        <TextView
                            android:id="@+id/tvWeightPrev"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="69"
                            android:textColor="@color/colorPrimary"
                            android:textSize="12sp" />

                        <ImageButton
                            android:id="@+id/btnWeightUp"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Weight up"
                            android:src="@drawable/baseline_keyboard_arrow_up_24" />

                        <FrameLayout
                            android:layout_width="88dp"
                            android:layout_height="40dp">

                            <TextView
                                android:id="@+id/tvWeightSelected"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="70"
                                android:textColor="@color/colorPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/flexifit_border"
                                android:clickable="false"
                                android:focusable="false"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <ImageButton
                            android:id="@+id/btnWeightDown"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Weight down"
                            android:src="@drawable/baseline_keyboard_arrow_down_24" />

                        <TextView
                            android:id="@+id/tvWeightNext"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="71"
                            android:textColor="@color/colorPrimary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- CENTER GUIDELINE -->
                    <androidx.constraintlayout.widget.Guideline
                        android:id="@+id/guidelineCenter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintGuide_percent="0.5" />

                    <!-- RIGHT: TARGET WEIGHT -->
                    <TextView
                        android:id="@+id/tvTargetWeightLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:text="Target Weight (kg)"
                        android:textColor="@color/colorPrimary"
                        android:paddingLeft="5dp"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/heightPicker"
                        app:layout_constraintStart_toStartOf="@id/guidelineCenter"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHorizontal_bias="0.5" />

                    <LinearLayout
                        android:id="@+id/targetWeightPicker"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/tvTargetWeightLabel"
                        app:layout_constraintStart_toStartOf="@id/guidelineCenter"
                        app:layout_constraintEnd_toEndOf="parent">

                        <TextView
                            android:id="@+id/tvTargetWeightPrev"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="64"
                            android:textColor="@color/colorPrimary"
                            android:textSize="12sp" />

                        <ImageButton
                            android:id="@+id/btnTargetWeightUp"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Target weight up"
                            android:src="@drawable/baseline_keyboard_arrow_up_24" />

                        <FrameLayout
                            android:layout_width="88dp"
                            android:layout_height="40dp">

                            <TextView
                                android:id="@+id/tvTargetWeightSelected"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="65"
                                android:textColor="@color/colorPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/flexifit_border"
                                android:clickable="false"
                                android:focusable="false"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <ImageButton
                            android:id="@+id/btnTargetWeightDown"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Target weight down"
                            android:src="@drawable/baseline_keyboard_arrow_down_24" />

                        <TextView
                            android:id="@+id/tvTargetWeightNext"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="66"
                            android:textColor="@color/colorPrimary"
                            android:textSize="12sp" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/btnConfirm"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:background="@drawable/btn_gradient"
        android:gravity="center"
        android:paddingLeft="40dp"
        android:paddingRight="40dp"
        android:text="Confirm"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>