<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <FrameLayout
        android:id="@+id/layoutWorkoutHero"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackWorkoutDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="18dp"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/baseline_arrow_left_ios_new_24" />

        <ImageView
            android:id="@+id/ivWorkoutHeroImage"
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:layout_marginTop="30dp"
            android:src="@drawable/ic_workout" />
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardWorkoutDetailContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="7dp"
        android:layout_marginEnd="7dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutWorkoutHero">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <View
                    android:layout_width="44dp"
                    android:layout_height="5dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_handle" />

                <TextView
                    android:id="@+id/tvWorkoutDetailTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Workout Name Pushup"
                    android:textColor="#111827"
                    android:textSize="24sp"
                    android:layout_marginTop="10dp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/labelMuscleGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Muscle Group"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWorkoutMuscleGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_chip_soft"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="Upper Body"
                    android:textColor="@color/gradientStart"
                    android:textStyle="bold"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/labelWorkoutStructure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Workout Structure"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutWorkoutStructureTags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvWorkoutSets"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_soft"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:text="3 Sets"
                            android:textColor="@color/gradientStart"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvWorkoutReps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_soft"
                            android:paddingHorizontal="12dp"
                            android:textColor="@color/gradientStart"
                            android:paddingVertical="8dp"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:text="8 Reps" />

                        <TextView
                            android:id="@+id/tvWorkoutRest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_soft"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:text="8s Rest"
                            android:textColor="@color/gradientStart"
                            android:textStyle="bold"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvWorkoutDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_soft"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:text="15 mins"
                            android:textColor="@color/gradientStart"
                            android:textStyle="bold"
                            android:textSize="12sp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/labelCaloriesBurned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Calories Burned"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWorkoutCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_chip_soft"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/gradientStart"
                    android:text="100 kcal"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/labelWorkoutDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Description"
                    android:textColor="#111827"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWorkoutDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Detailed description of the workout goes here."
                    android:textColor="#4B5563"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenWorkoutTutorial"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="28dp"
                    android:text="Open Tutorial"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@null"
                    android:background="@drawable/btn_gradient"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkExerciseDone"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="20dp"
                    android:text="Mark as Done"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="#10B981"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSkipExercise"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:text="Skip this Exercise"
                    android:textAllCaps="false"
                    android:textColor="#EF4444"
                    app:strokeColor="#EF4444"
                    app:cornerRadius="18dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>